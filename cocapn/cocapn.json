{
  "name": "businesslog-ai",
  "version": "1.0.0",
  "paradigm": "cocapn",
  "type": "vertical",
  "template": "businesslog",
  "description": "Your Business AI. Self-Hosted. Private. Powerful.",
  "features": [
    "multi-user",
    "role-based-access",
    "analytics-dashboard",
    "multi-channel",
    "a2a-protocol",
    "docker-first",
    "cloudflare-workers"
  ],
  "channels": {
    "web": { "enabled": true },
    "telegram": { "enabled": false },
    "discord": { "enabled": false },
    "whatsapp": { "enabled": false }
  },
  "roles": ["admin", "member", "viewer"],
  "deployment": {
    "primary": "docker",
    "alternative": "cloudflare-workers"
  },
  "agent": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "maxTokens": 4096,
    "temperature": 0.7
  }
}
